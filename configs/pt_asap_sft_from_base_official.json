{
  "data_paths": [
    "data/processed/sft/pt_sft_pianocore_asap_raw.jsonl"
  ],
  "test_size": 0.05,
  "block_size": 4096,
  "pretrained_model": "models/hf_pianist_transformer_base",
  "overlap_ratio": 0.5,
  "prior_token_keep_prob": 1.0,
  "output_dir": "./models/pt_asap_sft_from_base_official/",
  "overwrite_output_dir": true,
  "max_steps": -1,
  "num_train_epochs": 2,
  "save_steps": 400,
  "logging_steps": 10,
  "eval_steps": 100,
  "per_device_train_batch_size": 4,
  "gradient_accumulation_steps": 8,
  "lr_scheduler_type": "cosine",
  "learning_rate": 0.0005,
  "warmup_steps": 0,
  "warmup_ratio": 0,
  "save_total_limit": 50,
  "prediction_loss_only": true,
  "bf16": true,
  "report_to": "none",
  "logging_dir": "~/tf-logs/",
  "eval_strategy": "steps",
  "save_strategy": "epoch",
  "logging_strategy": "steps",
  "logging_first_step": true,
  "dataset_num_proc": 30,
  "dataloader_num_workers": 16,
  "dataloader_prefetch_factor": 4
}
